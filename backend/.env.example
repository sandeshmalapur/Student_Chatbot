# ---- Database (Supabase Postgres - Transaction Pooler URI) ----
# Get from: Supabase Dashboard -> Project Settings -> Database -> Connection string -> Transaction pooler
# NOTE: if your password has special characters (e.g. @), url-encode them (handled automatically in config.py via quote_plus if you paste raw password below)
DATABASE_URL=postgresql://postgres.bhuccfdydyquhpjybpws:<DB_PASSWORD>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ---- JWT ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=<GENERATE_A_RANDOM_HEX_SECRET>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Supabase (Storage + used for PDF files) ----
# Get from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://bhuccfdydyquhpjybpws.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<SUPABASE_SERVICE_ROLE_KEY>
SUPABASE_STORAGE_BUCKET=notes-pdfs

# ---- Qdrant ----
# Local docker-compose service name "qdrant" on port 6333, or Qdrant Cloud URL
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---- Groq (LLM) ----
# Get from: https://console.groq.com/keys
GROQ_API_KEY=<GROQ_API_KEY>
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Embeddings ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- CORS ----
FRONTEND_ORIGIN=http://localhost:5173
